LLM_PROVIDER="openai"
LLM_MODEL="openai/gpt-4o-mini"
LLM_API_KEY="your-openai-api-key"

EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL="openai/text-embedding-3-small"
EMBEDDING_API_KEY="your-openai-api-key"
EMBEDDING_DIMENSIONS="1536"

# --- Neon / PostgreSQL (used directly by app/database.py) ---
DB_PROVIDER='postgres'
DB_HOST='your-neon-host.neon.tech'
DB_PORT=5432
DB_USERNAME='your-db-username'
DB_PASSWORD='your-db-password'
DB_NAME='your-db-name'

# --- pgvector (Cognee's vector store, same Neon instance) ---
VECTOR_DB_PROVIDER='pgvector'
VECTOR_DB_HOST='your-neon-host.neon.tech'
VECTOR_DB_PORT=5432
VECTOR_DB_USERNAME='your-db-username'
VECTOR_DB_PASSWORD='your-db-password'
VECTOR_DB_NAME='your-db-name'

# --- Graph (store in Neon too via postgres adapter) ---
GRAPH_DATABASE_PROVIDER=postgres

# Cognee 1.2.2 turns on multi-user auth/access-control by default; this app
# has no login/session system, so both need to be off together.
ENABLE_BACKEND_ACCESS_CONTROL=false
REQUIRE_AUTHENTICATION=false

# --- Pool tuning (important for Neon's pooled/pgbouncer connections) ---
DATABASE_CONNECT_ARGS='{"statement_cache_size": 0, "prepared_statement_cache_size": 0}'
VECTOR_POOL_ARGS='{"pool_size": 2, "max_overflow": 2}'
POOL_ARGS='{"pool_size": 2, "max_overflow": 2, "pool_pre_ping": true, "pool_recycle": 60}'

# Disable session memory / extra LLM calls per query
CACHING=false
AUTO_FEEDBACK=false

# Logging verbosity. DEBUG shows pipeline/LLM/DB/graph internals (very noisy);
# INFO is the sane default for normal use. Bump to DEBUG when troubleshooting.
LOG_LEVEL="INFO"